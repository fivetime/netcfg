[Unit]
Description=netcfg network configuration daemon
Documentation=https://github.com/netcfg/netcfg
After=network-pre.target systemd-udevd.service
Before=network.target network-online.target
Wants=network.target

[Service]
Type=simple
ExecStart=/usr/bin/netcfg daemon
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
